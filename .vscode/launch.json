{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "lil_bro: GUI (windowed-equivalent)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "args": []
    },
    {
      "name": "lil_bro: --terminal CLI",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "args": ["--terminal"]
    },
    {
      "name": "lil_bro: Attach to running .exe (debugpy listener on :5678)",
      "type": "debugpy",
      "request": "attach",
      "connect": { "host": "127.0.0.1", "port": 5678 },
      "justMyCode": false
    }
  ]
}
