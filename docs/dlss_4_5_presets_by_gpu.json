  "generation_rules": {
    "50_series": {"architecture": "Blackwell", "fp8_support": true, "preset_policy": "Full DLSS 4.5. K = DLAA/Quality/Balanced, M = Performance, L = 4K Ultra Performance."},
    "40_series": {"architecture": "Ada Lovelace", "fp8_support": true, "preset_policy": "Same as 50-series for Super Resolution presets. (6X / Dynamic Frame Gen is 50-series only, but that's frame gen, not SR presets.)"},
    "30_series": {"architecture": "Ampere", "fp8_support": false, "preset_policy": "No FP8 => M/L carry a heavier cost. Recommended: stay on Preset K (DLSS 4) or 'Auto'. M/L usable only if you have FPS headroom."},
    "20_series": {"architecture": "Turing", "fp8_support": false, "dlss_supported": true, "preset_policy": "Supports DLSS 4.5 transformer Super Resolution, but Turing Tensor cores are FP16-only, so M/L are expensive (similar-to-worse than Ampere). Default to Preset K. No DLSS Frame Generation, no Multi Frame Generation."},
    "10_series": {"architecture": "Pascal", "fp8_support": false, "dlss_supported": false, "preset_policy": "NOT SUPPORTED - Pascal has no Tensor cores, so no version of DLSS runs and no preset applies. Use FSR, XeSS, or NVIDIA Image Scaling (NIS) instead."}
