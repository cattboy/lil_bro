{
  "title": "DLSS 4.5 Preset Guidance by GeForce RTX GPU (Desktop)",
  "last_updated": "2026-06-04",
  "important_context": {
    "what_drives_preset_choice": "GPU generation (FP8 hardware support) and DLSS output MODE/RESOLUTION. NOT VRAM capacity.",
    "vram_clarification": "K, L and M are all transformer models; the VRAM difference between them is negligible (tens of MB). VRAM footprint scales with OUTPUT resolution, not with the preset letter. The big VRAM consumer in DLSS is Frame Generation, and total usage depends on game textures/settings + resolution.",
    "no_gpu_locked_models": "All presets (K/L/M) run on every RTX GPU back to the 20 series. The difference is execution SPEED, gated by FP8 acceleration, not whether a card 'can' load the model.",
    "presets": {
      "K": "DLSS 4 (1st-gen transformer). NVIDIA default for DLAA / Quality / Balanced. Most robust with ray-traced denoisers.",
      "M": "DLSS 4.5 (2nd-gen transformer). Optimized/recommended for Performance mode.",
      "L": "DLSS 4.5 (2nd-gen transformer). Optimized/recommended for 4K Ultra Performance mode."
    },
    "transformer_upscaler_vram_footprint_MB": {
      "note": "Per DLSS SDK 310.3.0 (June 2025). Near-identical across K/L/M; scales with output resolution.",
      "1080p": 85.77,
      "1440p": 143.52,
      "4K": 307.37,
      "8K_approx": 1200,
      "cnn_model_1080p_reference": 60.83
    },
    "how_to_set": "NVIDIA app > Graphics tab > 'DLSS Override - Model Presets'. Choose 'Recommended' (auto-maps M/L/K by mode) or 'Custom' to force a specific preset. Power users can also force presets via NVIDIA Profile Inspector or DLSS Swapper.",
    "caveat": "In some ray-traced games, Presets M/L interact poorly with the game's denoiser; falling back to Preset K per-game can look better. Verified by Digital Foundry and community testing.",
